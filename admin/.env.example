# Admin console — copy to admin/.env
#
# Local API (direct Uvicorn, no nginx /api prefix):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#
# Against a deployed EC2:
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_PUBLIC_IP/api
#
# Production behind nginx path /console (set on EC2 by bootstrap):
# NEXT_PUBLIC_BASE_PATH=/console
#
# Local: leave BASE_PATH empty so the app runs at http://localhost:3001/
# NEXT_PUBLIC_BASE_PATH=
