# Spoto Ranger — root env (backend + EC2 deploy)
# Copy to `.env` and fill values. Never commit `.env`.
#
# Local Next apps also use:
#   frontend/.env.local  (see frontend/.env.example)
#   admin/.env           (see admin/.env.example)

ENVIRONMENT=production

# --- Public URLs (set before Next builds on EC2) ---
# IP mode:   http://YOUR_PUBLIC_IP/api
# Domain:    https://yourdomain.com/api
NEXT_PUBLIC_API_BASE_URL=http://YOUR_PUBLIC_IP/api

# --- Backend ---
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=YOUR_PUBLIC_IP,localhost,127.0.0.1

# Comma-separated browser origins (no trailing slash)
# Same-origin /console admin needs only the site origin.
# Local admin on :3001 also needs http://localhost:3001
CORS_ALLOWED_ORIGINS=http://YOUR_PUBLIC_IP,http://localhost:3000,http://localhost:3001

SECURE_SSL_REDIRECT=false

# --- PostgreSQL (required — SQLite is not supported) ---
DATABASE_URL=postgresql://spoto:CHANGE_ME@127.0.0.1:5432/spoto_ranger
POSTGRES_DB=spoto_ranger
POSTGRES_USER=spoto
POSTGRES_PASSWORD=CHANGE_ME

# Redis is unused — leave blank
REDIS_URL=

# --- OTP / SMS (2Factor + DLT) ---
SMS_API_KEY=
DLT_SENDER_ID=
DLT_TEMPLATE_ID=
DLT_PE_ID=
# Optional internal bypass (empty = real SMS only)
DEFAULT_LOGIN_PHONE_NUMBER=
DEFAULT_OTP=
OTP_EXPIRY_MINUTES=10
MIN_WITHDRAWAL_AMOUNT=100
