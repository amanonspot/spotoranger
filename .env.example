# Spoto Ranger — min-cost single EC2 (PostgreSQL on same box)
ENVIRONMENT=production
APP_NAME="Spoto Ranger Platform"

# Frontend — set BEFORE npm run build
# IP mode (cheap):  http://YOUR_PUBLIC_IP/api
# Domain later:     https://yourdomain.com/api
NEXT_PUBLIC_API_BASE_URL=http://YOUR_PUBLIC_IP/api
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Backend
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=YOUR_PUBLIC_IP,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://YOUR_PUBLIC_IP
SECURE_SSL_REDIRECT=false

# PostgreSQL on the same EC2 (SQLite is not supported)
DATABASE_URL=postgresql://spoto:CHANGE_ME@127.0.0.1:5432/spoto_ranger

# Redis is unused by the app — leave blank
REDIS_URL=

# OTP / SMS (2Factor + DLT)
SMS_API_KEY=
DLT_SENDER_ID=
DLT_TEMPLATE_ID=
DLT_PE_ID=
# Optional internal bypass phone (leave empty for real SMS-only)
DEFAULT_LOGIN_PHONE_NUMBER=
DEFAULT_OTP=
OTP_EXPIRY_MINUTES=10
MIN_WITHDRAWAL_AMOUNT=100

# Used by deploy/bootstrap-ec2.sh to create the DB role
POSTGRES_DB=spoto_ranger
POSTGRES_USER=spoto
POSTGRES_PASSWORD=CHANGE_ME
